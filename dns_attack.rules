# Rule 1
# 这个规则适合检测 DNS tunnel 的通用特征
# alert dns any any -> any any (
#     msg:"Suspicious DNS TXT query with long query name - possible DNS tunneling";
#     dns.rrtype:TXT;
#     dns.query;
#     bsize:>100;
#     sid:9000003;
#     rev:1;
# )
alert dns any any -> any any (msg:"Suspicious DNS TXT query with long query name - possible DNS tunneling"; dns.rrtype:TXT; dns.query; bsize:>100; sid:9000003; rev:1;)


# Rule 2
# 检测 iodine 风格 TXT tunnel，域名 + 长度组合
# alert dns any any -> any any (
#     msg:"Likely iodine DNS tunnel - long TXT query under ggy666.tk";
#     dns.rrtype:TXT;
#     dns.query;
#     content:"ggy666.tk";
#     nocase;
#     bsize:>80;
#     sid:9000005;
#     rev:1;
# )
alert dns any any -> any any (msg:"Likely iodine DNS tunnel - long TXT query under ggy666.tk"; dns.rrtype:TXT; dns.query; content:"ggy666.tk"; nocase; bsize:>80; sid:9000005; rev:1;)

# The Rule for Demo and work in live status:

alert udp any any -> any 5300 (msg:"DNS Tunnel Lab - UDP 5300 DNS query observed"; sid:9002001; rev:1;)
alert udp any any -> any 5300 (msg:"DNS Tunnel Lab - suspicious domain ggy666.tk in raw DNS query"; content:"|06|ggy666|02|tk|00|"; sid:9002002; rev:1;)
alert udp any any -> any 5300 (msg:"DNS Tunnel Lab - TXT query over UDP 5300"; content:"|00 10 00 01|"; sid:9002003; rev:1;)
alert udp any any -> any 5300 (msg:"DNS Tunnel Lab - long UDP DNS query possible tunneling"; dsize:>100; sid:9002004; rev:1;)
alert udp any any -> any 5300 (msg:"DNS Tunnel Lab - possible encoded subdomain payload"; pcre:"/[A-Za-z0-9_-]{20,}/"; sid:9002005; rev:1;)
alert udp any any -> any 5300 (msg:"DNS Tunnel Lab - high frequency DNS tunnel queries over UDP 5300"; detection_filter:track by_src, count 10, seconds 30; sid:9002006; rev:1;)
